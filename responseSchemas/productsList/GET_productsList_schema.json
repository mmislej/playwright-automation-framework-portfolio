{
  "type": "object",
  "required": ["responseCode", "products"],
  "properties": {
    "responseCode": { "type": "integer" },
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "price", "brand", "category"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "price": { "type": "string" },
          "brand": { "type": "string" },
          "category": {
            "type": "object",
            "required": ["usertype", "category"],
            "properties": {
              "usertype": {
                "type": "object",
                "required": ["usertype"],
                "properties": {
                  "usertype": { "type": "string" }
                }
              },
              "category": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
